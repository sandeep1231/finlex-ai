        "Permitted Disclosures"
      ]
    },
    "sale_deed": {
      "name": "Sale Deed (Immovable Property)",
      "applicable_laws": ["Transfer of Property Act, 1882", "Registration Act, 1908", "Indian Stamp Act, 1899 (state amendments)"],
      "key_clauses": [
