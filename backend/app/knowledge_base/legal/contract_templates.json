        "Security Deposit",
        "Lock-in Period",
        "Maintenance Responsibilities",
        "Subletting Restrictions",
        "Termination and Notice Period",
        "Registration (mandatory if term > 11 months)",
        "TDS on Rent (Section 194I/194IB)"
      ],
