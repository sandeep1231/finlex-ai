# ============================================
# FinLex AI - Environment Configuration
# ============================================
# Copy this file to .env and fill in your values

# --- Application ---
APP_NAME=FinLex AI
APP_ENV=development
DEBUG=true
SECRET_KEY=change-this-to-a-random-secret-key-min-32-chars
API_PREFIX=/api/v1
CORS_ORIGINS=http://localhost:3000

# --- Database ---
DATABASE_URL=postgresql+asyncpg://finlex:finlex_password@localhost:5432/finlex_db
DATABASE_ECHO=false

# --- Redis ---
REDIS_URL=redis://localhost:6379/0

# --- LLM Configuration ---
# Option 1: Gemini (free)
GOOGLE_API_KEY=your-google-api-key
GOOGLE_MODEL=models/gemini-2.5-flash

# Option 2: OpenAI (paid)
OPENAI_API_KEY=sk-your-openai-api-key
OPENAI_MODEL=gpt-4o

# Option 3: Ollama (local/private)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3

# Active LLM provider: "gemini", "openai", or "ollama"
LLM_PROVIDER=gemini

# --- Embeddings ---
EMBEDDING_MODEL=models/gemini-embedding-001

# --- Vector Database ---
CHROMA_PERSIST_DIR=./chroma_data
CHROMA_COLLECTION_NAME=finlex_knowledge

# --- Auth (Clerk) ---
CLERK_SECRET_KEY=sk_test_your-clerk-secret-key
CLERK_PUBLISHABLE_KEY=pk_test_your-clerk-publishable-key
CLERK_WEBHOOK_SECRET=whsec_your-webhook-secret

# --- Razorpay ---
RAZORPAY_KEY_ID=rzp_test_your-razorpay-key
RAZORPAY_KEY_SECRET=your-razorpay-secret

# --- File Storage ---
UPLOAD_DIR=./uploads
MAX_UPLOAD_SIZE_MB=50

# --- Rate Limiting ---
RATE_LIMIT_PER_MINUTE=30
RATE_LIMIT_PER_DAY=500
